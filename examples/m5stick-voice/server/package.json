{
  "name": "m5stick-voice-server",
  "version": "0.0.0",
  "private": true,
  "description": "Cloudflare Worker that transcribes m5stick-voice audio via the OpenAI Realtime API and serves a live transcript + FFT viewer.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types env.d.ts --include-runtime false",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inanimate/resident": "^0.1.0",
    "agents": "^0.10.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260411.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.1"
  }
}
