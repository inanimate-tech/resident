.pio/
build/
.vscode/
*.o
*.a

# ESP-IDF build artifacts (per-example)
examples/*/build/
examples/*/managed_components/
examples/*/components/
examples/*/sdkconfig
examples/*/sdkconfig.old
examples/*/dependencies.lock

# PlatformIO test build artifacts
test/unit/.pio/

# Python bytecode (from tools/run-tests.py and friends)
__pycache__/

# Git worktrees (created by superpowers' using-git-worktrees skill)
.worktrees/

# clangd LSP index (per-project)
.cache/

# Per-developer Claude Code artifacts (not for shared tree)
.claude/settings.local.json
.claude/napkin.md
.claude/projects/

# Superpowers plan/spec output — kept out of the repo to avoid leaking
# personal context, in-progress thinking, and absolute paths.
docs/superpowers/
examples/*/docs/superpowers/

# Local pack output (pio pkg pack / compote component pack)
dist/
